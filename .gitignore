# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.iml

# iOS / Xcode (generated by xcodegen)
ios/TacticalMaps.xcodeproj/
ios/TacticalMaps.xcworkspace/
ios/Pods/
ios/DerivedData/
ios/.swiftpm/
ios/*.xcuserdata

# Android / Gradle
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/gradle/wrapper/gradle-wrapper.jar
android/captures/
android/.cxx/
*.keystore
!debug.keystore

# Secrets — NEVER commit
**/secrets.properties
**/google-services.json
**/*.api-key
**/maps.key

# Sample / test PDFs — fetched on demand via scripts/fetch_samples.sh
samples/*.pdf

# Build artifacts
*.log
*.hprof

# SwiftPM cache (when using -clonedSourcePackagesDirPath)
spm-cache/
